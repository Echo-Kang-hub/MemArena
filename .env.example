# =========================
# App
# =========================
APP_ENV=dev
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173

# =========================
# LLM Provider Routing
# Values: api | ollama | local
# =========================
DEFAULT_LLM_PROVIDER=api
DEFAULT_EMBEDDING_PROVIDER=ollama

# =========================
# Function-Oriented LLM Routing
# 按功能划分：每个模型独立选择 api | ollama | local
# =========================
CHAT_LLM_PROVIDER=api
CHAT_API_BASE_URL=
CHAT_API_KEY=
CHAT_API_MODEL=
CHAT_OLLAMA_BASE_URL=
CHAT_OLLAMA_MODEL=
CHAT_LOCAL_MODEL_PATH=

JUDGE_LLM_PROVIDER=api
JUDGE_API_BASE_URL=
JUDGE_API_KEY=
JUDGE_API_MODEL=
JUDGE_OLLAMA_BASE_URL=
JUDGE_OLLAMA_MODEL=
JUDGE_LOCAL_MODEL_PATH=

# Summarizer 专用 LLM 路由（可独立于 Chat/Judge）
SUMMARIZER_LLM_PROVIDER=
SUMMARIZER_API_BASE_URL=
SUMMARIZER_API_KEY=
SUMMARIZER_API_MODEL=
SUMMARIZER_OLLAMA_BASE_URL=
SUMMARIZER_OLLAMA_MODEL=
SUMMARIZER_LOCAL_MODEL_PATH=

# EntityExtractor 专用 LLM 路由（可独立于 Chat/Judge）
ENTITY_LLM_PROVIDER=
ENTITY_API_BASE_URL=
ENTITY_API_KEY=
ENTITY_API_MODEL=
ENTITY_OLLAMA_BASE_URL=
ENTITY_OLLAMA_MODEL=
ENTITY_LOCAL_MODEL_PATH=

# Reflector 专用 LLM 路由（可独立于 Chat/Judge/Summarizer/Entity）
REFLECTOR_LLM_PROVIDER=
REFLECTOR_API_BASE_URL=
REFLECTOR_API_KEY=
REFLECTOR_API_MODEL=
REFLECTOR_OLLAMA_BASE_URL=
REFLECTOR_OLLAMA_MODEL=
REFLECTOR_LOCAL_MODEL_PATH=

# Embedding 路由可独立于 Chat/Judge 配置
EMBEDDING_PROVIDER=
EMBEDDING_API_BASE_URL=
EMBEDDING_API_KEY=
EMBEDDING_API_MODEL=
EMBEDDING_OLLAMA_BASE_URL=
EMBEDDING_OLLAMA_MODEL=
EMBEDDING_LOCAL_MODEL_PATH=
LOCAL_INFER_DEVICE=cpu

# =========================
# Retrieval Relevance Weights (Graph/Relational)
# 说明：用于 EntityExtractor 三元组/属性检索相关度融合
# =========================
GRAPH_RELEVANCE_LEXICAL_WEIGHT=0.45
GRAPH_RELEVANCE_ENTITY_WEIGHT=0.35
GRAPH_RELEVANCE_COMPLETENESS_WEIGHT=0.20
GRAPH_RELEVANCE_HINT_WEIGHT=0.10
GRAPH_RELEVANCE_FALLBACK_LEXICAL_WEIGHT=0.90
GRAPH_RELEVANCE_FALLBACK_HINT_WEIGHT=0.10

RELATIONAL_RELEVANCE_LEXICAL_WEIGHT=0.45
RELATIONAL_RELEVANCE_ENTITY_WEIGHT=0.35
RELATIONAL_RELEVANCE_COMPLETENESS_WEIGHT=0.20
RELATIONAL_RELEVANCE_HINT_WEIGHT=0.10
RELATIONAL_RELEVANCE_FALLBACK_LEXICAL_WEIGHT=0.90
RELATIONAL_RELEVANCE_FALLBACK_HINT_WEIGHT=0.10

# Context Assembler runtime controls
CONTEXT_TOKEN_BUDGET=1200
GRAPH_REASONING_MAX_CHAINS=24

# =========================
# Databases / Engines
# =========================
SQLITE_PATH=./data/memarena.db
CHROMA_PERSIST_DIR=./data/chroma
REQUEST_LOG_PATH=./data/logs/request_audit.jsonl
CHROMA_COLLECTION_NAME=memarena_memory
MILVUS_URI=http://localhost:19530
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=memarena
