# =========================
# App
# =========================
APP_ENV=dev
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
FRONTEND_ORIGIN=http://localhost:5173

# =========================
# LLM Provider Routing
# Values: api | ollama | local
# =========================
DEFAULT_LLM_PROVIDER=api
DEFAULT_EMBEDDING_PROVIDER=ollama

# =========================
# API Providers (OpenAI / Anthropic / etc.)
# =========================
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com/v1
OPENAI_CHAT_MODEL=gpt-4o-mini
OPENAI_EMBED_MODEL=text-embedding-3-small

# 未使用 Anthropic 时可保留空值，无需删除键名
ANTHROPIC_API_KEY=
ANTHROPIC_BASE_URL=https://api.anthropic.com
ANTHROPIC_CHAT_MODEL=claude-3-5-sonnet-latest

# =========================
# Ollama
# =========================
OLLAMA_BASE_URL=http://localhost:11434
# 不使用 Ollama 作为 LLM 时可留空
OLLAMA_LLM_MODEL=qwen2.5:7b
OLLAMA_EMBED_MODEL=Qwen/Qwen3-Embedding-0.6B

# =========================
# Local (HuggingFace Transformers)
# =========================
LOCAL_LLM_MODEL_PATH=
# 若 embedding 走 ollama/api，本地路径可留空
LOCAL_EMBED_MODEL_PATH=

# =========================
# Databases / Engines
# =========================
SQLITE_PATH=./backend/data/memarena.db
CHROMA_PERSIST_DIR=./backend/data/chroma
CHROMA_COLLECTION_NAME=memarena_memory
MILVUS_URI=http://localhost:19530
NEO4J_URI=bolt://localhost:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=memarena
